# ============================================================
#  COLECTIVO RESERVAS — Variables de entorno
#  Copiá este archivo como ".env" para uso local
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# ── MercadoPago ───────────────────────────────────────────────
# TEST- para pruebas, APP_USR- para cobros reales
MP_ACCESS_TOKEN=TU_ACCESS_TOKEN_ACA
MP_PRODUCCION=false

# ── Configuración ─────────────────────────────────────────────
PRECIO_ASIENTO=3300
BASE_URL=http://localhost:3000
NOMBRE_SERVICIO=Reservas Transporte Pablo

# ── Admin (contraseña del panel) ──────────────────────────────
ADMIN_PASSWORD=cambiame123

# ── Email con Resend (opcional) ───────────────────────────────
# Gratis en resend.com — hasta 3000 emails/mes
# Dejá vacío si no querés emails por ahora
RESEND_API_KEY=
EMAIL_FROM=reservas@tudominio.com
